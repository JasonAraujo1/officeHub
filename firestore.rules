rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      // leitura liberada p/ usuários autenticados (busca por e-mail nas solicitações)
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /reports/{reportId} {
        allow read: if request.auth != null && (request.auth.uid == uid || (resource.data.taggedUids != null && request.auth.uid in resource.data.taggedUids));
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /events/{eventId} {
        allow read: if request.auth != null && (request.auth.uid == uid || (resource.data.taggedUids != null && request.auth.uid in resource.data.taggedUids));
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /connections/{cid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        // o outro usuário cria a conexão ao aceitar a solicitação
        allow write: if request.auth != null;
      }
      match /notifications/{nid} {
        allow read, update, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null;
      }
    }
    match /invitations/{id} {
      allow read: if request.auth != null && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
    }
  }
}
