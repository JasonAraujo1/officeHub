# ===== n8n =====
# URL do webhook (Production URL do node Webhook no seu n8n)
VITE_N8N_WEBHOOK_URL=

# IMPORTANTE: as chaves do AssemblyAI e da OpenAI NÃO ficam aqui.
# Elas vão como credenciais dentro do n8n (lado servidor).
